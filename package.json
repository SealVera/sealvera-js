    "ai-agent",
    "agentic-ai",
    "hipaa",
    "gdpr",
    "soc2",
    "fintech",
    "regulated-ai",
    "responsible-ai"
  ],
  "author": "SealVera <hello@sealvera.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sealvera/sealvera-js"
  },
  "homepage": "https://app.sealvera.com/docs",
  "bugs": {
    "url": "https://github.com/sealvera/sealvera-js/issues"
  },
